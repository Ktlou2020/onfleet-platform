# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=replace-with-a-strong-random-string
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./data/onfleet.db

# File uploads — set to a path on your persistent volume in production
# Example (Railway): UPLOAD_DIR=/app/backend/data/uploads
# Leave unset for local dev (defaults to backend/uploads/)
UPLOAD_DIR=

# Paystack (https://paystack.com)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=http://localhost:5173/payments/callback

# Paystack Subscription Plan Codes (create plans in your Paystack dashboard first)
# Set interval=monthly, currency=ZAR, and copy the plan_code here
# R1,499/month — up to 20 bikes
PAYSTACK_PLAN_SMALL=PLN_xxxxxxxxxxxxxx
# R3,999/month — up to 60 bikes
PAYSTACK_PLAN_MEDIUM=PLN_xxxxxxxxxxxxxx
# R6,999/month — up to 100 bikes
PAYSTACK_PLAN_LARGE=PLN_xxxxxxxxxxxxxx

# Notifications (Twilio for SMS/WhatsApp - optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# Email (SMTP - optional, required for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@onfleet.africa
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Frontend
FRONTEND_URL=http://localhost:5173

# Live superadmin bootstrap (optional but recommended for production)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_FULL_NAME=
SUPERADMIN_PHONE=
